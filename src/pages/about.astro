---
import BaseLayout from '../layouts/BaseLayout.astro';

const timeline = [
  {
    when: '2023 — Present',
    role: 'Software Engineer',
    org: 'CelLink Corporation',
    note: 'Own 15+ production internal tools serving 200+ users across two manufacturing sites — validation systems, ETL pipelines, ERP integrations, and AI assistants. Shipped production LLM tooling before it was common at the company.',
  },
  {
    when: '2022',
    role: 'Engineering Intern',
    org: 'Ecolab',
    note: 'Computer-vision and edge-computing work — early exposure to C/C++ and deploying inference close to the hardware.',
  },
  {
    when: '2019 — 2023',
    role: 'B.S., Class of 2023',
    org: 'University of Minnesota',
    note: 'Formula SAE / Gopher Motorsports — built and raced things under real deadlines with real consequences.',
  },
];

const principles = [
  {
    k: 'Correctness first',
    v: 'Most of my work runs a factory floor. A wrong number is worse than no number — so I build for traceability and fail loudly.',
  },
  {
    k: 'Ship, then refine',
    v: 'A tool in someone\u2019s hands beats a perfect tool in a branch. I get to v1 fast and iterate against real usage.',
  },
  {
    k: 'Tools over heroics',
    v: 'If I do something twice, I automate it. Internal tooling, dev workflow, deploys — leverage compounds.',
  },
];
---

<BaseLayout
  title="About — Erick Ti"
  description="Erick Ti is a software engineer who builds production AI, data, and full-stack systems for real-world operations."
>
  {/* ---- intro ---- */}
  <section class="wrap intro-sec">
    <p class="kicker" data-reveal>// about</p>
    <h1 class="display intro" data-reveal>
      A generalist engineer who likes <span class="accent">shipping</span> the
      hard parts.
    </h1>
  </section>

  <section class="wrap bio-sec">
    <div class="bio-grid">
      <div class="bio" data-reveal>
        <p>
          I&rsquo;m a software engineer based in Fremont, California. Day to
          day I build the internal systems a manufacturing company runs on
          &mdash; the validation tools, data pipelines, and reporting that
          decide whether product ships.
        </p>
        <p>
          My favorite work sits where messy reality meets clean engineering:
          a natural-language assistant that lets non-technical staff query
          production databases, an ERP traceability layer built on recursive
          SQL, telemetry dashboards generated from code. I shipped production
          LLM systems early &mdash; that&rsquo;s the thread through most of
          what I do now.
        </p>
        <p>
          Outside the day job I build things for the love of it: a full-stack
          collection tracker, a music recommender that listens to the audio
          itself. Same instinct, fewer constraints.
        </p>
        <p class="bio-note mono">
          <span class="accent">Note —</span> placeholder copy. Swap this for
          your own voice; the layout stays.
        </p>
      </div>

      <aside class="quick" data-reveal>
        <div class="q-row"><span class="q-k">Based</span><span>Fremont, CA</span></div>
        <div class="q-row"><span class="q-k">Role</span><span>Software Engineer</span></div>
        <div class="q-row"><span class="q-k">Core</span><span>Python · TS · SQL</span></div>
        <div class="q-row"><span class="q-k">Also</span><span>C#/.NET · AWS</span></div>
        <div class="q-row"><span class="q-k">Open to</span><span>Hybrid / remote SWE</span></div>
        <a href="/resume.pdf" class="btn q-btn">
          Download resume <span class="arr">↗</span>
        </a>
      </aside>
    </div>
  </section>

  {/* ---- experience ---- */}
  <section class="section wrap">
    <hr class="rule" />
    <div class="label exp-label" data-reveal>
      <span>Experience</span>
      <span class="idx">trace</span>
    </div>
    <ol class="timeline">
      {
        timeline.map((t, i) => (
          <li class="t-item" data-reveal data-reveal-delay={i * 90}>
            <span class="t-when mono">{t.when}</span>
            <div class="t-body">
              <h3 class="t-role">
                {t.role} <span class="t-org">/ {t.org}</span>
              </h3>
              <p class="t-note">{t.note}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  {/* ---- principles ---- */}
  <section class="section wrap">
    <hr class="rule" />
    <div class="label" data-reveal>
      <span>How I Work</span>
      <span class="idx">003</span>
    </div>
    <div class="principles">
      {
        principles.map((p, i) => (
          <div class="principle" data-reveal data-reveal-delay={i * 80}>
            <span class="p-num mono">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="p-k">{p.k}</h3>
            <p class="p-v">{p.v}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .intro-sec { padding-block: clamp(3rem, 8vh, 6rem) 1rem; }
  .intro { margin-top: 1rem; max-width: 16ch; }

  .bio-sec { padding-block: 2.5rem 1rem; }
  .bio-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }
  .bio > p { color: var(--text-dim); font-size: 1.05rem; }
  .bio > p + p { margin-top: 1.1rem; }
  .bio-note {
    font-size: 0.8rem !important;
    color: var(--text-faint) !important;
    border: 1px solid var(--border);
    padding: 0.7rem 0.9rem;
    margin-top: 1.6rem;
  }

  .quick {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 0.4rem 0;
  }
  .q-row {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    border-bottom: 1px solid var(--border);
  }
  .q-k { color: var(--text-faint); text-transform: uppercase; font-size: 0.7rem; }
  .q-btn {
    width: calc(100% - 2.2rem);
    margin: 1rem 1.1rem;
    justify-content: center;
  }

  /* ---- timeline ---- */
  .exp-label { margin-top: 3rem; }
  .timeline { list-style: none; margin-top: 2.4rem; }
  .t-item {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: 1.5rem;
    padding: 1.8rem 0;
    border-bottom: 1px solid var(--border);
  }
  .t-item:first-child { border-top: 1px solid var(--border); }
  .t-when {
    font-size: 0.8rem;
    color: var(--accent);
    padding-top: 0.2rem;
  }
  .t-role {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.6rem;
    line-height: 1.2;
  }
  .t-org { color: var(--text-dim); }
  .t-note {
    color: var(--text-dim);
    margin-top: 0.6rem;
    max-width: 58ch;
    font-size: 0.95rem;
  }

  /* ---- principles ---- */
  .principles {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
    margin-top: 2.4rem;
  }
  .principle {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 1.6rem;
  }
  .p-num { color: var(--accent); font-size: 0.85rem; }
  .p-k {
    font-family: var(--font-serif);
    font-weight: 400;
    font-size: 1.5rem;
    margin-top: 0.7rem;
  }
  .p-v {
    color: var(--text-dim);
    margin-top: 0.6rem;
    font-size: 0.92rem;
  }

  @media (max-width: 860px) {
    .bio-grid { grid-template-columns: 1fr; }
    .quick { max-width: 380px; }
    .t-item { grid-template-columns: 1fr; gap: 0.5rem; }
    .principles { grid-template-columns: 1fr; }
  }
</style>
