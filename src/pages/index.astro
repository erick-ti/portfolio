---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import FoilAppraisalCard from '../components/FoilAppraisalCard.astro';
import IntroSequence from '../components/IntroSequence.astro';

const all = (await getCollection('projects', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
const featured = all.filter((p) => p.data.featured);

// Millennium gets the signature spotlight; the rest fill the asymmetric
// "Selected Work" grid, led by OTIS (the strongest professional proof).
const spotlight = featured.find((p) => p.id === 'millennium') ?? null;
const grid = featured.filter((p) => p.id !== 'millennium');
const lead = grid.find((p) => p.id === 'teams-ai-assistant') ?? grid[0] ?? null;
const others = grid.filter((p) => p.id !== lead?.id);

const stats = [
  { value: '15+', label: 'production tools shipped' },
  { value: '200+', label: 'internal users served' },
  { value: '$12M+', label: 'shipments validated' },
  { value: '2 sites', label: 'manufacturing footprint' },
];

const lanes = [
  {
    code: 'AI Systems',
    blurb: 'LLM assistants, tool-calling, retrieval, embeddings.',
  },
  {
    code: 'Product / Full-Stack',
    blurb: 'Typed APIs, React frontends, the whole stack.',
  },
  {
    code: 'Data & Operations',
    blurb: 'Pipelines, telemetry, ERP integration, SQL at scale.',
  },
  {
    code: 'Developer Tools',
    blurb: 'Workflow automation and reproducible environments.',
  },
];
const laneCount = (c: string) => all.filter((p) => p.data.category === c).length;
---

<BaseLayout>
  <IntroSequence />

  {/* ============================ HERO ============================ */}
  <section class="hero">
    <div class="wrap hero-grid">
      <div class="hero-main">
        <p class="kicker h-anim" style="--d:0ms">
          // software engineer — ai · data · product
        </p>
        <h1 class="display h-anim" style="--d:90ms">
          I build production systems for the <span class="ember"
            >messy<span class="ember-sparks" aria-hidden="true"
              ><i style="--x:10%;--y:30%;--dx:-1.3em;--dy:-.5em;--d:0s;--s:1"></i><i
                style="--x:22%;--y:66%;--dx:-1.1em;--dy:.7em;--d:.7s;--s:.8"></i><i
                style="--x:35%;--y:12%;--dx:-.4em;--dy:-1.2em;--d:.3s;--s:.9"></i><i
                style="--x:50%;--y:50%;--dx:0;--dy:-1.4em;--d:1.1s;--s:1"></i><i
                style="--x:62%;--y:10%;--dx:.5em;--dy:-1.2em;--d:.5s;--s:.7"></i><i
                style="--x:86%;--y:32%;--dx:1.3em;--dy:-.5em;--d:1.5s;--s:.95"></i><i
                style="--x:90%;--y:60%;--dx:1.4em;--dy:.4em;--d:.9s;--s:.85"></i><i
                style="--x:78%;--y:80%;--dx:1em;--dy:1em;--d:2s;--s:.8"></i><i
                style="--x:50%;--y:88%;--dx:0;--dy:1.3em;--d:1.3s;--s:.65"></i><i
                style="--x:30%;--y:82%;--dx:-.9em;--dy:1em;--d:2.4s;--s:.9"></i><i
                style="--x:45%;--y:30%;--dx:-.2em;--dy:-.9em;--d:1.8s;--s:.7"></i
              ></span></span
          > parts of the real world.
        </h1>
        <p class="hero-sub h-anim" style="--d:200ms">
          AI assistants, data-heavy platforms, and internal products —
          shipped where correctness, scale, and real users actually
          matter. Not toy projects.
        </p>
        <p class="hero-note h-anim" style="--d:300ms">
          // the test I care about — does it survive real users, real money,
          an actual factory floor?
        </p>
        <div class="hero-cta h-anim" style="--d:400ms">
          <a href="/projects" class="btn btn--solid">
            View selected work <span class="arr">→</span>
          </a>
          <a href="/about" class="btn">About me</a>
        </div>
      </div>

      <aside class="panel h-anim" style="--d:400ms" aria-label="Status">
        <div class="panel-row">
          <span class="p-key">loc</span>
          <span class="p-val">Fremont, CA · USA</span>
        </div>
        <div class="panel-row">
          <span class="p-key">role</span>
          <span class="p-val">Software Engineer</span>
        </div>
        <div class="panel-row">
          <span class="p-key">focus</span>
          <span class="p-val">Production AI / LLM systems</span>
        </div>
        <div class="panel-row">
          <span class="p-key">status</span>
          <span class="p-val">
            <span class="live"></span>open to new roles
          </span>
        </div>
        <div class="panel-row">
          <span class="p-key">stack</span>
          <span class="p-val">Python · TypeScript · SQL</span>
        </div>
      </aside>
    </div>
  </section>

  {/* ========================= STAT STRIP ========================= */}
  <section class="wrap">
    <hr class="rule" />
    <ul class="stats">
      {
        stats.map((s, i) => (
          <li data-reveal data-reveal-delay={i * 80}>
            <span class="s-value mono">{s.value}</span>
            <span class="s-label">{s.label}</span>
          </li>
        ))
      }
    </ul>
    <hr class="rule" />
  </section>

  {/* ======================= FEATURED WORK ======================= */}
  <section class="section wrap">
    <div class="label" data-reveal>
      <span>Selected Work</span>
      <span class="idx">01 / 03</span>
    </div>
    <h2 class="heading sec-head" data-reveal>
      A closer look at the work.
    </h2>

    <div class="features">
      {lead && <ProjectCard project={lead} index={1} lead />}
      {
        others.length > 0 && (
          <div class="feature-rest">
            {others.map((p, i) => (
              <ProjectCard project={p} index={i + 2} />
            ))}
          </div>
        )
      }
    </div>

    <a href="/projects" class="all-link mono" data-reveal>
      See all {all.length} projects <span class="arr">→</span>
    </a>
  </section>

  {/* ===================== SIGNATURE SPOTLIGHT ===================== */}
  {
    spotlight && (
      <section class="spotlight-band">
        <div class="wrap section">
          <div class="label" data-reveal>
            <span>Signature Build</span>
            <span class="idx">02 / 03</span>
          </div>
          <h2 class="heading sec-head" data-reveal>
            A collection, priced like a portfolio.
          </h2>

          <div class="spotlight" data-reveal>
            <div class="spotlight-copy">
              <p class="spotlight-lede">
                <strong>{spotlight.data.title}</strong> is a full-stack
                valuation system for a trading-card collection — Django/DRF
                and Next.js, tracking per-lot cost basis, market movement, and
                catalog-match confidence. The card beside this is one
                holding&rsquo;s appraisal readout.
              </p>

              {spotlight.data.metrics.length > 0 && (
                <ul class="spotlight-metrics">
                  {spotlight.data.metrics.slice(0, 3).map((m) => (
                    <li>
                      <span class="m-value mono">{m.value}</span>
                      <span class="m-label">{m.label}</span>
                    </li>
                  ))}
                </ul>
              )}

              <p class="spotlight-caption">
                Illustrative readout modeled on Millennium&rsquo;s lot-cost
                valuation pipeline — per-lot cost basis, append-only daily
                snapshots, and confidence-scored catalog matching. Values are
                illustrative.
              </p>

              <div class="spotlight-links">
                {spotlight.data.links.live && (
                  <a
                    class="tlink"
                    href={spotlight.data.links.live}
                    target="_blank"
                    rel="noopener"
                  >
                    Live app ↗
                  </a>
                )}
                {spotlight.data.links.repo && (
                  <a
                    class="tlink"
                    href={spotlight.data.links.repo}
                    target="_blank"
                    rel="noopener"
                  >
                    Public repo ↗
                  </a>
                )}
                <a class="tlink" href={`/projects/${spotlight.id}`}>
                  Case study →
                </a>
              </div>
            </div>

            <div class="spotlight-card">
              <FoilAppraisalCard />
            </div>
          </div>
        </div>
      </section>
    )
  }

  {/* ======================== LANES ======================== */}
  <section class="section wrap">
    <hr class="rule" />
    <div class="label lanes-label" data-reveal>
      <span>Disciplines</span>
      <span class="idx">03 / 03</span>
    </div>
    <h2 class="heading sec-head" data-reveal>
      Four lanes. One engineer.
    </h2>
    <p class="lanes-intro" data-reveal>
      The work spans a few distinct disciplines. Filter the project
      index by whichever one matches the role you&rsquo;re hiring for.
    </p>

    <div class="lanes">
      {
        lanes.map((lane, i) => (
          <a
            href={`/projects?lane=${encodeURIComponent(lane.code)}`}
            class="lane"
            data-reveal
            data-reveal-delay={i * 70}
          >
            <div class="lane-top">
              <span class="lane-code mono">{lane.code}</span>
              <span class="lane-count mono">
                {String(laneCount(lane.code)).padStart(2, '0')}
              </span>
            </div>
            <p class="lane-blurb">{lane.blurb}</p>
            <span class="lane-arr mono">filter →</span>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<script>
  // Pause the "messy" ember (sparks + glow flicker) when the hero scrolls out
  // of view — no idle GPU/paint cost off-screen.
  const heroEl = document.querySelector('.hero');
  const emberEl = document.querySelector('.ember');
  if (heroEl && emberEl) {
    const io = new IntersectionObserver(
      ([entry]) => emberEl.classList.toggle('ember-paused', !entry.isIntersecting),
      { rootMargin: '0px' }
    );
    io.observe(heroEl);
  }
</script>

<style>
  /* ---- hero ---- */
  .hero { padding-block: clamp(3.5rem, 9vh, 7rem) clamp(3rem, 6vh, 5rem); }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.65fr 1fr;
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: start;
  }
  .hero-sub {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-dim);
    max-width: 46ch;
    margin-top: 1.6rem;
  }
  .display { margin-top: 1.5rem; }
  .hero-note {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.6;
    color: var(--text-faint);
    max-width: 50ch;
    margin-top: 1.5rem;
    border-left: 2px solid var(--accent-line);
    padding-left: 0.9rem;
  }
  .hero-cta { display: flex; gap: 0.8rem; margin-top: 2.2rem; flex-wrap: wrap; }

  /* hero load animation */
  .h-anim {
    opacity: 0;
    transform: translateY(16px);
    animation: rise 0.8s var(--ease) forwards;
    animation-delay: var(--d);
  }
  /* hold the hero until the intro hands off, then let it rise into place */
  :global(html.intro:not(.intro-go)) .h-anim { animation-play-state: paused; }
  @keyframes rise {
    to { opacity: 1; transform: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .h-anim { animation: none; opacity: 1; transform: none; }
  }

  /* ---- "messy" — ember glow + drifting sparks ---- */
  .ember {
    position: relative;
    display: inline-block;
    color: var(--accent);
    font-style: italic;
    text-shadow: 0 0 7px rgba(240, 168, 48, 0.45), 0 0 18px rgba(235, 120, 35, 0.28);
    animation: ember-flicker 3.2s ease-in-out infinite;
  }
  @keyframes ember-flicker {
    0%, 100% { text-shadow: 0 0 7px rgba(240, 168, 48, 0.42), 0 0 18px rgba(235, 120, 35, 0.25); }
    45% { text-shadow: 0 0 11px rgba(255, 185, 70, 0.6), 0 0 26px rgba(235, 120, 35, 0.4); }
    72% { text-shadow: 0 0 8px rgba(240, 168, 48, 0.48), 0 0 20px rgba(235, 120, 35, 0.3); }
  }

  .ember-sparks {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .ember-sparks i {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: calc(0.09em * var(--s, 1));
    height: calc(0.09em * var(--s, 1));
    border-radius: 50%;
    background: radial-gradient(circle, #ffe2a6 0%, var(--accent) 50%, rgba(235, 120, 35, 0) 72%);
    box-shadow: 0 0 5px 1px rgba(240, 168, 48, 0.6);
    opacity: 0;
    animation: ember-drift 2.8s var(--d, 0s) ease-out infinite;
  }
  /* sparks radiate outward in all directions (per-spark --dx/--dy vector) */
  @keyframes ember-drift {
    0% { transform: translate(0, 0) scale(0.3); opacity: 0; }
    18% { opacity: 1; }
    70% { opacity: 0.7; }
    100% { transform: translate(var(--dx, 0), var(--dy, 0)) scale(0.25); opacity: 0; }
  }
  /* pause the ember (glow flicker + sparks) when the hero is off-screen */
  .ember-paused,
  .ember-paused .ember-sparks i { animation-play-state: paused; }

  /* ---- instrument panel ---- */
  .panel {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 0.4rem 0;
    position: relative;
  }
  .panel::before {
    content: 'SYS.STATUS';
    position: absolute;
    top: -0.62rem;
    left: 1rem;
    background: var(--bg);
    padding: 0 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    color: var(--text-faint);
  }
  .panel-row {
    display: flex;
    gap: 1rem;
    padding: 0.62rem 1.1rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    border-bottom: 1px solid var(--border);
  }
  .panel-row:last-child { border-bottom: 0; }
  .p-key {
    color: var(--text-faint);
    width: 3.4rem;
    flex: none;
    text-transform: uppercase;
    font-size: 0.7rem;
    align-self: center;
  }
  .p-val { color: var(--text); }
  .live {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--signal-green);
    margin-right: 0.45rem;
    box-shadow: 0 0 8px var(--signal-green);
  }

  /* ---- stats ---- */
  .stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    list-style: none;
    padding-block: 2rem;
  }
  .stats li {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-inline: 1.5rem;
    border-left: 1px solid var(--border);
  }
  .stats li:first-child { padding-left: 0; border-left: 0; }
  .s-value {
    font-size: clamp(1.8rem, 3.5vw, 2.7rem);
    color: var(--accent);
    letter-spacing: -0.02em;
  }
  .s-label {
    font-size: 0.78rem;
    color: var(--text-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* ---- section heads ---- */
  .sec-head { margin-top: 1.3rem; max-width: 18ch; }

  /* ---- featured (asymmetric: full-width lead + two beneath) ---- */
  .features {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    margin-top: 2.8rem;
  }
  .feature-rest {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  /* ---- signature spotlight — the rhythm-breaking band ---- */
  .spotlight-band {
    position: relative;
    z-index: 1;
    background: var(--bg-elevated);
    border-block: 1px solid var(--border);
  }
  .spotlight {
    display: grid;
    grid-template-columns: 1fr minmax(280px, 360px);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
    margin-top: 2.6rem;
  }
  .spotlight-copy { display: flex; flex-direction: column; gap: 1.5rem; }
  .spotlight-lede {
    font-size: clamp(1.05rem, 1.6vw, 1.25rem);
    line-height: 1.6;
    color: var(--text-dim);
    max-width: 52ch;
  }
  .spotlight-lede strong { color: var(--text); font-weight: 600; }
  .spotlight-metrics {
    display: flex;
    flex-wrap: wrap;
    gap: 1.4rem 2.4rem;
    list-style: none;
    padding-block: 1.2rem;
    border-block: 1px solid var(--border);
  }
  .spotlight-metrics li { display: flex; flex-direction: column; gap: 0.2rem; }
  .spotlight-metrics .m-value {
    font-size: 1.5rem;
    color: var(--accent);
    letter-spacing: -0.01em;
  }
  .spotlight-metrics .m-label {
    font-size: 0.72rem;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .spotlight-caption {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    line-height: 1.7;
    color: var(--text-faint);
    max-width: 56ch;
  }
  .spotlight-links { display: flex; flex-wrap: wrap; gap: 1.4rem; }
  .all-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--text-dim);
    border-bottom: 1px solid var(--accent-line);
    padding-bottom: 2px;
    transition: color 0.2s var(--ease);
  }
  .all-link:hover { color: var(--accent); }

  /* ---- lanes ---- */
  .lanes-label { margin-top: 3rem; }
  .lanes-intro {
    color: var(--text-dim);
    max-width: 52ch;
    margin-top: 1rem;
    font-size: 0.98rem;
  }
  .lanes {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-top: 2.6rem;
  }
  .lane {
    border: 1px solid var(--border);
    background: var(--bg-elevated);
    padding: 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    min-height: 170px;
    transition: border-color 0.25s var(--ease), transform 0.25s var(--ease);
  }
  .lane:hover { border-color: var(--accent); transform: translateY(-3px); }
  .lane-top {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .lane-code {
    font-size: 0.82rem;
    color: var(--text);
    letter-spacing: 0.02em;
  }
  .lane-count { font-size: 0.78rem; color: var(--accent); }
  .lane-blurb {
    font-size: 0.86rem;
    color: var(--text-dim);
    line-height: 1.5;
    flex: 1;
  }
  .lane-arr {
    font-size: 0.74rem;
    color: var(--text-faint);
    transition: color 0.2s var(--ease);
  }
  .lane:hover .lane-arr { color: var(--accent); }

  /* ---- responsive ---- */
  @media (max-width: 940px) {
    .hero-grid { grid-template-columns: 1fr; }
    .panel { max-width: 420px; }
    .feature-rest { grid-template-columns: 1fr; }
    .stats { grid-template-columns: repeat(2, 1fr); gap: 1.5rem 0; }
    .stats li:nth-child(3) { padding-left: 0; border-left: 0; }
    .lanes { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 860px) {
    .spotlight { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .lanes { grid-template-columns: 1fr; }
    .stats { grid-template-columns: 1fr; }
    .stats li, .stats li:nth-child(3) {
      padding-left: 0; border-left: 0;
      border-top: 1px solid var(--border);
      padding-top: 1.2rem;
    }
    .stats li:first-child { border-top: 0; padding-top: 0; }
  }
</style>
