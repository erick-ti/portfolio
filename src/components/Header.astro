---
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const nav = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Work' },
  { href: '/about', label: 'About' },
];
---

<header class="site-header">
  <div class="wrap inner">
    <a href="/" class="brand" aria-label="Erick Ti, home">
      <span class="brand-mark">▌</span>
      <span class="brand-name">ERICK&nbsp;TI</span>
      <span class="brand-role">/ swe</span>
    </a>

    <nav aria-label="Primary">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.href) }]}
          >
            {item.label}
          </a>
        ))
      }
      <a
        href="/resume.pdf"
        class="nav-link nav-resume"
        target="_blank"
        rel="noopener"
      >
Résumé<span class="arr">↗</span>
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 86%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border);
  }
  .inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
  }
  .brand {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.92rem;
    letter-spacing: 0.05em;
  }
  .brand-mark {
    color: var(--accent);
    animation: blink 1.3s steps(1) infinite;
  }
  @keyframes blink {
    0%, 50% { opacity: 1; }
    51%, 100% { opacity: 0; }
  }
  .brand-name { font-weight: 500; }
  .brand-role { color: var(--text-faint); font-size: 0.78rem; }

  nav {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--text-dim);
    padding: 0.45rem 0.7rem;
    transition: color 0.2s var(--ease);
  }
  .nav-link:hover { color: var(--text); }
  .nav-link.active { color: var(--accent); }
  .nav-resume {
    border: 1px solid var(--accent-line);
    color: var(--accent);
    margin-left: 0.4rem;
  }
  .nav-resume:hover { background: var(--accent); color: var(--bg); border-color: var(--accent); }
  .nav-resume .arr { margin-left: 0.3rem; }

  @media (max-width: 540px) {
    .brand-role { display: none; }
    .nav-link { padding: 0.45rem 0.5rem; font-size: 0.72rem; }
  }
</style>
