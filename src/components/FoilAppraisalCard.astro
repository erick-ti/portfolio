---
/**
 * FoilAppraisalCard — the homepage's one signature interactive artifact.
 *
 * A single trading card rendered as a financial instrument: a pointer-tracked
 * tilt + gold holographic sheen confined to the art window, over a matte,
 * crisp appraisal readout. Ported dependency-free from Millennium's
 * `frontend/src/components/landing/foil-card.tsx` and remapped onto the
 * portfolio's amber tokens — no React, no animation library.
 *
 * The figures are ILLUSTRATIVE (labeled on the card). What the card actually
 * proves is the valuation *model* — a cost-basis-vs-market split, an unrealized
 * P&L, and a complete/EXACT-match confidence tier — which is real and live; the
 * embedding section supplies the caption + live link.
 */

// 90-day sparkline, computed at build time → static <polyline> (no client JS).
const SPARK = [168, 182, 176, 201, 224, 215, 238, 270, 258, 296, 312];
const W = 120, H = 30, PAD = 2;
const min = Math.min(...SPARK);
const max = Math.max(...SPARK);
const span = max - min || 1;
const points = SPARK.map((v, i) => {
  const x = PAD + (i / (SPARK.length - 1)) * (W - 2 * PAD);
  const y = H - PAD - ((v - min) / span) * (H - 2 * PAD);
  return `${x.toFixed(1)},${y.toFixed(1)}`;
}).join(' ');
const trend = SPARK[SPARK.length - 1] >= SPARK[0] ? 'rising' : 'falling';
---

<figure class="foil-card" aria-label="Illustrative trading-card appraisal, Millennium valuation model">
  <div class="fc-head">
    <span class="fc-badge">Secret Rare</span>
    <span class="fc-set">LOB-001</span>
  </div>

  <div class="foil-art">
    <svg
      class="fc-crest"
      viewBox="0 0 100 100"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M50 8 L86 38 L50 92 L14 38 Z" />
      <path d="M14 38 L86 38" />
      <path d="M50 8 L38 38 L50 92" />
      <path d="M50 8 L62 38 L50 92" />
      <path d="M38 38 L50 8 M62 38 L50 8" opacity="0.5" />
    </svg>
    <div class="foil-shine" aria-hidden="true"></div>
    <div class="foil-glare" aria-hidden="true"></div>
  </div>

  <div class="fc-id">
    <p class="fc-name">Blue-Eyes White Dragon</p>
    <p class="fc-edition">Legend of Blue Eyes · 1st Edition</p>
  </div>

  <dl class="fc-readout">
    <div class="fc-row">
      <dt>Market</dt>
      <dd>$312.40 <span class="fc-gain">▲ +4.2%</span></dd>
    </div>
    <div class="fc-row">
      <dt>Cost basis</dt>
      <dd class="fc-dim">$180.00</dd>
    </div>
    <div class="fc-row">
      <dt>Unrealized</dt>
      <dd class="fc-gain">+$132.40</dd>
    </div>
    <div class="fc-row fc-row--spark">
      <dt>90-day</dt>
      <dd>
        <span class="sr-only">90-day trend: {trend}, ${SPARK[0]} to ${SPARK[SPARK.length - 1]}.</span>
        <svg class="fc-spark" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" aria-hidden="true">
          <polyline
            points={points}
            fill="none"
            stroke="var(--accent)"
            stroke-width="1.5"
            stroke-linejoin="round"
            stroke-linecap="round"
          />
        </svg>
      </dd>
    </div>
    <div class="fc-row">
      <dt>Coverage</dt>
      <dd class="fc-cov">✓ complete · EXACT match</dd>
    </div>
  </dl>

  <p class="fc-demo">Figures illustrative · model is live</p>
</figure>

<style>
  /* ---- the card object (small radius — it IS a trading card) ---- */
  .foil-card {
    --rx: 0deg;
    --ry: 0deg;
    --px: 50%;
    --py: 50%;
    --bg-x: 50%;
    --bg-y: 50%;
    --foil-opacity: 0;
    width: 100%;
    max-width: 20rem;
    margin-inline: auto;
    border: 1px solid var(--border);
    /* edge-light instead of a drop shadow (drop shadows read as SaaS cards) */
    box-shadow: inset 0 1px 0 0 rgba(240, 168, 48, 0.18);
    background: var(--bg-elevated);
    border-radius: 12px;
    overflow: hidden;
    transform: perspective(1100px) rotateY(var(--rx)) rotateX(var(--ry));
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform;
  }
  .foil-card[data-interacting='true'] { transition: none; }
  /* touch / reduced-motion: a premium fixed sheen, no listener */
  .foil-card[data-static='true'] {
    --foil-opacity: 0.4;
    --bg-x: 36%;
    --bg-y: 40%;
  }

  /* ---- header ---- */
  .fc-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem 1rem 0;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .fc-badge {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 0.2rem 0.45rem;
  }
  .fc-set { color: var(--text-faint); }

  /* ---- art window — the only place the foil plays ---- */
  .foil-art {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    margin: 0.75rem 1rem 0;
    height: 11rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: radial-gradient(circle at 50% 36%, #1b1b20, var(--bg));
  }
  .fc-crest { width: 6rem; color: var(--accent); }

  .foil-shine,
  .foil-glare {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: var(--foil-opacity);
    transition: opacity 0.55s ease;
  }
  .foil-card[data-interacting='true'] .foil-shine,
  .foil-card[data-interacting='true'] .foil-glare { transition: none; }

  /* gold-dominant metallic sweep with two razor-thin spectral glints —
     lamp-lit gold leaf, never an oil slick */
  .foil-shine {
    background-image: repeating-linear-gradient(
      104deg,
      transparent 0%,
      oklch(0.78 0.075 84 / 0.4) 6%,
      oklch(0.89 0.1 89 / 0.62) 10.5%,
      oklch(0.84 0.1 200 / 0.12) 11.1%,
      oklch(0.84 0.11 330 / 0.12) 11.7%,
      oklch(0.74 0.085 66 / 0.42) 15.5%,
      oklch(0.63 0.06 50 / 0.34) 21%,
      transparent 28%
    );
    background-size: 250% 250%;
    background-position: var(--bg-x) var(--bg-y);
    mix-blend-mode: color-dodge;
    filter: brightness(0.94) contrast(1.32) saturate(0.72);
  }
  .foil-glare {
    background-image: radial-gradient(
      circle at var(--px) var(--py),
      rgba(255, 242, 208, 0.42),
      rgba(255, 242, 208, 0.07) 16%,
      transparent 40%
    );
    mix-blend-mode: overlay;
  }

  /* ---- identity ---- */
  .fc-id { padding: 0.85rem 1rem 0; }
  .fc-name {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    line-height: 1.1;
    color: var(--text);
  }
  .fc-edition {
    margin-top: 0.15rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-faint);
  }

  /* ---- appraisal readout — matte, crisp, tabular ---- */
  .fc-readout {
    margin-top: 0.85rem;
    padding: 0.9rem 1rem 0.4rem;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-variant-numeric: tabular-nums slashed-zero;
    font-feature-settings: 'tnum' 1, 'zero' 1;
  }
  .fc-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }
  .fc-row + .fc-row { margin-top: 0.5rem; }
  .fc-row dt {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-faint);
  }
  .fc-row dd { color: var(--text); }
  .fc-dim { color: var(--text-dim); }
  /* gains in amber — honors the single warm accent (green stays live-only) */
  .fc-gain { color: var(--accent); }
  .fc-cov { color: var(--accent); }
  .fc-row--spark { align-items: center; }
  .fc-row--spark dd { width: 7rem; }
  .fc-spark { width: 100%; height: 1.6rem; display: block; }

  /* on-card honesty marker — so the card never misleads, even alone */
  .fc-demo {
    padding: 0.7rem 1rem 0.95rem;
    font-family: var(--font-mono);
    font-size: 0.58rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-faint);
  }
</style>

<script>
  // Vanilla pointer loop ported 1:1 from foil-card.tsx (rAF-throttled, writes
  // CSS custom props). No listener on touch / reduced-motion — a static sheen.
  const card = document.querySelector('.foil-card');
  if (card instanceof HTMLElement) {
    const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const coarse = matchMedia('(pointer: coarse)').matches;
    if (reduce || coarse) {
      card.dataset.static = 'true';
    } else {
      let raf = 0;
      const set = (k: string, v: string) => card.style.setProperty(k, v);
      const onMove = (event: PointerEvent) => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const r = card.getBoundingClientRect();
          const px = Math.min(1, Math.max(0, (event.clientX - r.left) / r.width));
          const py = Math.min(1, Math.max(0, (event.clientY - r.top) / r.height));
          set('--px', `${(px * 100).toFixed(1)}%`);
          set('--py', `${(py * 100).toFixed(1)}%`);
          set('--bg-x', `${(20 + px * 60).toFixed(1)}%`);
          set('--bg-y', `${(20 + py * 60).toFixed(1)}%`);
          set('--rx', `${((px - 0.5) * 15).toFixed(2)}deg`);
          set('--ry', `${((0.5 - py) * 15).toFixed(2)}deg`);
          set('--foil-opacity', '0.85');
          card.dataset.interacting = 'true';
        });
      };
      const onLeave = () => {
        cancelAnimationFrame(raf);
        card.dataset.interacting = 'false';
        set('--rx', '0deg');
        set('--ry', '0deg');
        set('--px', '50%');
        set('--py', '50%');
        set('--bg-x', '50%');
        set('--bg-y', '50%');
        set('--foil-opacity', '0');
      };
      card.addEventListener('pointermove', onMove);
      card.addEventListener('pointerleave', onLeave);
    }
  }
</script>
