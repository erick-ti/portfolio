---
const year = new Date().getFullYear();

// Plain mailto so contact works with or without JS. The address is a burnable
// Cloudflare-routed alias — rotate it if it ever gets spammed.
const social = [
  { label: 'GitHub', href: 'https://github.com/erick-ti' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/erick-ti' },
];
---

<footer class="site-footer">
  <hr class="rule" />
  <div class="wrap inner">
    <div class="cta" data-reveal>
      <p class="kicker avail"><span class="avail-dot" aria-hidden="true"></span>open to new roles</p>
      <p class="line">
        I build AI, full-stack, and data systems that ship. <a
          class="tlink"
          href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#104;&#101;&#108;&#108;&#111;&#64;&#101;&#114;&#105;&#99;&#107;&#116;&#105;&#46;&#99;&#111;&#109;"
          >Let&rsquo;s talk →</a
        >
      </p>
    </div>

    <div class="meta">
      <nav class="links" aria-label="Contact">
        <a class="flink" href="&#109;&#97;&#105;&#108;&#116;&#111;&#58;&#104;&#101;&#108;&#108;&#111;&#64;&#101;&#114;&#105;&#99;&#107;&#116;&#105;&#46;&#99;&#111;&#109;">Email</a>
        {
          social.map((l) => (
            <a href={l.href} class="flink" target="_blank" rel="noopener">
              {l.label}
              <span class="arr">↗</span>
            </a>
          ))
        }
      </nav>
      <p class="colophon mono">
        © {year} Erick Ti · Designed &amp; built with Astro
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer { margin-top: 2rem; }
  .inner { padding-block: clamp(2rem, 4vh, 3rem); }
  .cta { margin-bottom: 1.75rem; }
  .avail { display: inline-flex; align-items: center; gap: 0.5rem; }
  .avail-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--signal-green);
    animation: avail-pulse 2.4s ease-in-out infinite;
  }
  @keyframes avail-pulse {
    0%, 100% { box-shadow: 0 0 0 0 transparent; opacity: 0.8; }
    50%      { box-shadow: 0 0 8px 1px var(--signal-green); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) { .avail-dot { animation: none; } }
  .line {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.3vw, 1.65rem);
    line-height: 1.25;
    margin-top: 0.55rem;
    max-width: 36ch;
  }
  .meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1.25rem;
    border-top: 1px solid var(--border);
    padding-top: 1.5rem;
  }
  .links { display: flex; gap: 1.5rem; }
  .flink {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-dim);
    transition: color 0.2s var(--ease);
  }
  .flink:hover { color: var(--accent); }
  .flink .arr { font-size: 0.7rem; margin-left: 0.15rem; }
  .colophon { font-size: 0.7rem; color: var(--text-faint); }
</style>
