---
import '@fontsource/instrument-serif/400.css';
import '@fontsource/instrument-serif/400-italic.css';
import '@fontsource-variable/hanken-grotesk';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'Erick Ti · Software Engineer',
  description = 'Erick Ti builds production systems for the messy parts of the real world: AI assistants, data-heavy platforms, and internal products used where correctness matters.',
  image,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = image ? new URL(image, Astro.site) : undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta
      name="twitter:card"
      content={ogImage ? 'summary_large_image' : 'summary'}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    <meta name="theme-color" content="#0b0b0d" />

    <!-- Arm the homepage intro before first paint (no flash). Plays on every
         homepage load; skipped for reduced-motion and every non-homepage page. -->
    <script is:inline>
      (function () {
        try {
          var reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
          // Plays on every load of the homepage (not reduced-motion).
          if (location.pathname === '/' && !reduce) {
            document.documentElement.classList.add('intro');
            // hard fallback: never let the hero stay hidden if JS stalls
            setTimeout(function () {
              document.documentElement.classList.remove('intro');
            }, 4000);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      // Staggered scroll reveal — disabled automatically for users
      // who prefer reduced motion (handled in CSS, but we also skip
      // observing so nothing ever sits hidden).
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const items = document.querySelectorAll<HTMLElement>('[data-reveal]');

      if (reduce) {
        items.forEach((el) => el.classList.add('in-view'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                const el = entry.target as HTMLElement;
                const delay = Number(el.dataset.revealDelay ?? 0);
                window.setTimeout(() => el.classList.add('in-view'), delay);
                io.unobserve(el);
              }
            });
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        items.forEach((el) => io.observe(el));
      }
    </script>

    <script>
      // Count-up animation for headline stat values. Numeric values animate
      // from 0 when scrolled into view; non-numeric ones (e.g. "Per-lot",
      // "Audio-native") and before/after metrics ("11s → 0.5s") stay static.
      // Skipped entirely under prefers-reduced-motion (final values shown).
      (() => {
        if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const parse = (txt) => {
          if (txt.includes('→')) return null;
          const m = txt.match(/^(\D*?)([\d][\d,]*\.?\d*)(.*)$/);
          if (!m) return null;
          const target = parseFloat(m[2].replace(/,/g, ''));
          if (!isFinite(target)) return null;
          const decimals = (m[2].split('.')[1] || '').length;
          return { prefix: m[1], suffix: m[3], target, decimals, comma: m[2].includes(',') };
        };
        const fmt = (n, info) => {
          const v = info.comma
            ? n.toLocaleString('en-US', { minimumFractionDigits: info.decimals, maximumFractionDigits: info.decimals })
            : n.toFixed(info.decimals);
          return info.prefix + v + info.suffix;
        };
        const run = (el, info) => {
          const dur = 1100, t0 = performance.now();
          const ease = (t) => 1 - Math.pow(1 - t, 3);
          const tick = (now) => {
            const t = Math.min(1, (now - t0) / dur);
            el.textContent = fmt(info.target * ease(t), info);
            if (t < 1) requestAnimationFrame(tick);
            else el.textContent = fmt(info.target, info);
          };
          requestAnimationFrame(tick);
        };
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting) return;
            const el = e.target, info = parse(el.textContent.trim());
            if (info) { el.textContent = fmt(0, info); run(el, info); }
            io.unobserve(el);
          });
        }, { threshold: 0.4 });
        document.querySelectorAll('.s-value, .m-value, .lead-hero-value').forEach((el) => {
          if (parse(el.textContent.trim())) io.observe(el);
        });
      })();
    </script>
  </body>
</html>
